# .husky/pre-push
# Läuft vor "git push". Letzter Check bevor Code an GitHub geht.
# Bei Fehler → Push wird abgebrochen.

echo "▶ Running pre-push checks..."

# 1. Vollständiger TypeScript-Check
echo "  → TypeScript..."
npm run typecheck || {
  echo "✗ TypeScript errors. Push aborted."
  exit 1
}

# 2. Alle Unit + Integration Tests (E2E läuft erst in CI, dauert zu lange)
echo "  → Unit + Integration tests..."
npm run test:run || {
  echo "✗ Tests failed. Push aborted."
  echo "  Run 'npm run test:ui' to debug."
  exit 1
}

# 3. Build-Check (kompiliert es überhaupt?)
# Optional — auskommentieren wenn lokaler Build zu langsam ist
# echo "  → Build check..."
# npm run build || {
#   echo "✗ Build failed. Push aborted."
#   exit 1
# }

echo "✓ All pre-push checks passed. Pushing to remote..."
